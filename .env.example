# Required: Telegram user API credentials from https://my.telegram.org
SCAVENGER_API_ID=1234567
SCAVENGER_API_HASH=0123456789abcdef0123456789abcdef

# Required: chats/channels to monitor (CSV).
# Accepts numeric IDs and/or usernames.
# Examples: -1001234567890,@mychannel,my_group
SCAVENGER_TARGETS='["your_channel"]'

# Authentication session (choose one method).
# Recommended for servers: put an already authorized Telethon string session.
SCAVENGER_SESSION_STRING=
# Alternative: path/name for a local Telethon session file.
SCAVENGER_SESSION_NAME=/app/data/session/scavenger

# Storage and validation limits.
# Directory where valid keyboxes are written.
SCAVENGER_OUTPUT_DIR=/app/data/keyboxes
# Maximum XML size in bytes.
SCAVENGER_MAX_XML_SIZE=20480

# Network behavior for remote list fetches.
# Request timeout in seconds.
SCAVENGER_REQUEST_TIMEOUT_SECONDS=15
# Retries for failed HTTP calls (0 disables retries).
SCAVENGER_NETWORK_RETRIES=2
# Cache lifetime in seconds for banned/revocation responses.
SCAVENGER_CACHE_TTL_SECONDS=3600
# Poll interval in seconds for non-subscribed channels (0 disables polling).
SCAVENGER_UNSUBSCRIBED_POLL_SECONDS=60
# Periodic revocation refresh interval in seconds.
SCAVENGER_REVOCATION_REFRESH_SECONDS=21600

# Logging level: DEBUG, INFO, WARNING, ERROR.
SCAVENGER_LOG_LEVEL=INFO

# Remote and local data sources used by validation.
SCAVENGER_BANNED_SERIALS_URL=https://raw.githubusercontent.com/daboynb/autojson/refs/heads/main/banned.txt
SCAVENGER_REVOCATION_URL=https://android.googleapis.com/attestation/status
SCAVENGER_REVOCATION_FALLBACK_PATH=/app/res/json/status.json
SCAVENGER_LEAKED_SERIALS_PATH=/app/leaks.txt
